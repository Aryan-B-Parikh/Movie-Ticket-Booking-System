# ===================================
# Movie Ticket Booking System
# .gitignore
# ===================================

# =====================================
# Node.js / Backend
# =====================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
.pnpm-debug.log*

# Environment variables
.env
.env.local
.env.development
.env.test
.env.production

# Build outputs
dist/
build/
*.tsbuildinfo
.cache/

# =====================================
# Python
# =====================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
env.bak/
venv.bak/
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.coverage
htmlcov/
*.egg-info/
*.egg

# =====================================
# MySQL / Database
# =====================================
*.sql.backup
*.sql.bak
*.dump
*.log
*.ibd
*.frm
mysql-data/
db-backups/*.sql
!database/schema/*.sql
!database/seeds/*.sql
!database/migrations/**/*.sql
!database/procedures/*.sql
!database/triggers/*.sql
!database/views/*.sql

# =====================================
# IDE / Editors
# =====================================
# VSCode
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/

# JetBrains
.idea_modules/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~
.netrwhist

# Emacs
*~
\#*\#
.\#*

# =====================================
# Operating System
# =====================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.directory

# =====================================
# Logs
# =====================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*

# =====================================
# Testing
# =====================================
coverage/
.nyc_output/
test-results/
junit.xml

# =====================================
# Temporary Files
# =====================================
tmp/
temp/
*.tmp
*.temp
*.swp
*.bak

# =====================================
# Secrets & Credentials
# =====================================
*.key
*.pem
*.p12
*.pfx
*.cer
*.crt
secrets/
credentials/
.secrets
config/secrets.json

# =====================================
# Documentation Generated Files
# =====================================
docs/build/
docs/_build/
site/

# =====================================
# Project Specific
# =====================================
# Ignore local database config (use .env instead)
backend/src/config/database.local.json

# Ignore uploaded files (if any)
uploads/
public/uploads/

# Ignore stress test results
backend/tests/stress/results/

# Ignore benchmark results
scripts/benchmark-results/

# =====================================
# Keep Empty Directories
# =====================================
!.gitkeep
