    {
      "name": "Bookings (CRITICAL)",
      "item": [
        {
          "name": "Create Booking",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"showId\": {{show_id}},\n  \"seatIds\": [1, 2],\n  \"paymentMethod\": \"CREDIT_CARD\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/bookings",
              "host": ["{{base_url}}"],
              "path": ["bookings"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Booking creation status\", function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([201, 409]); // Success or conflict",
                  "});",
                  "",
                  "if (pm.response.code === 201) {",
                  "    pm.test(\"Booking created successfully\", function () {",
                  "        const response = pm.response.json();",
                  "        pm.expect(response.success).to.be.true;",
                  "        pm.expect(response.data).to.have.property('booking');",
                  "        pm.expect(response.data.booking).to.have.property('id');",
                  "        pm.expect(response.data.booking).to.have.property('status', 'CONFIRMED');",
                  "        pm.collectionVariables.set('booking_id', response.data.booking.id);",
                  "    });",
                  "}",
                  "",
                  "if (pm.response.code === 409) {",
                  "    pm.test(\"Booking conflict handled properly\", function () {",
                  "        const response = pm.response.json();",
                  "        pm.expect(response.success).to.be.false;",
                  "        pm.expect(response.error.code).to.eql('BOOKING_CONFLICT');",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
